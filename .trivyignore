# ── Python build tools (builder stage only) ───────────────────────
# wheel unpack path traversal — CVE-2026-24049
# wheel/pip are only in the builder stage. The final Alpine image
# gets only the installed packages via --prefix copy. No wheel at runtime.
CVE-2026-24049

# ── Alpine OS packages (unfixed upstream) ─────────────────────────
# These are in Alpine base packages with no patch available yet.
# All require local access (AV:L) or have no known public exploit.
# ignore-unfixed:true in the action handles most, listed here as backup.

# libssl/openssl — Alpine 3.x, no patch released yet
CVE-2024-9143
# musl libc — Alpine 3.23, no upstream patch
CVE-2025-26519
# libxml2 — bundled in Alpine Python, no fix
CVE-2024-40896
# nghttp2 in curl — not exposed as HTTP/2 server in this service
CVE-2025-46727
